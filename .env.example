# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Pushover (https://pushover.net)
PUSHOVER_USER_KEY=your_pushover_user_key
